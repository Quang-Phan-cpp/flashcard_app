<p style="color: green"><%= notice %></p>

<% content_for :title, "Flashcards" %>

<h1>Flashcards</h1>

<div id="flashcards">
  <% @flashcards.each do |flashcard| %>
    <%= render flashcard %>
    <p>
      <%= link_to "Show this flashcard", flashcard %>
    </p>
  <% end %>
</div>

<%= link_to "New flashcard", new_flashcard_path %>
